          "top_nav": { "title": "Caution", "show_back_button": true, "show_power_button": false },
          "status_type": "warning",
          "status_headline": "Full Spend!",
          "text": "This transaction spends its entire input value. No change is coming back to your wallet.",
          "button_list": ["Continue"],
          "is_bottom_list": true,
          "warning_edges": false
        }
      },
      {
        "name": "dire_warning",
