CLAUDE.md
.claude/

# Production font-pack output (reproducible from scenarios + catalogs + fonts)
/lang-packs/
# Localized scenarios (test-only output of tools/i18n/gen_localized_scenarios.py)
tools/scenarios/localized/
# Throwaway shaping-spike output (regenerate: spike_shape.py -> --shape-spike ->
# spike_compare.py). Subset TTFs, run table, reference + device + diff PNGs.
tools/i18n/spike_out/
# Production-pack validation output (regenerate: validate_runs.py). Oracle +
# device PNGs diffed for the release-validation gate.
tools/i18n/validate_out/
# Throwaway scratch dir: dev screenshots, montages, zoom crops, fetched refs.
# (Was the untracked 'review/'; renamed to .tmp/ as a conventional scratch space.)
.tmp/
